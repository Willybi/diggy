{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/badges/**",
              "components/buttons/**",
              "components/page/**",
              "components/table/**",
              "components/tags/**",
              "ui_kits/diggy/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:in-lib|not-in-lib|platform|rating|neutral)$/]",
        "message": "<Badge> variant must be one of 'in-lib' | 'not-in-lib' | 'platform' | 'rating' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|icon|children|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, icon, children, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|accent|ghost-accent|danger)$/]",
        "message": "<Button> variant must be one of 'ghost' | 'accent' | 'ghost-accent' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm)$/]",
        "message": "<Button> size must be one of 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PageHead'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|count|actions|key|ref|className|style|children)$/]",
        "message": "<PageHead> doesn't accept that prop. Declared props: title, count, actions."
      },
      {
        "selector": "JSXOpeningElement[name.name='StyleTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:pillar|depth|children|key|ref|className|style|children)$/]",
        "message": "<StyleTag> doesn't accept that prop. Declared props: pillar, depth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StyleTag'] > JSXAttribute[name.name='pillar'] > Literal[value!=/^(?:house|techno|trance|dnb|hardcore|harddance|autres)$/]",
        "message": "<StyleTag> pillar must be one of 'house' | 'techno' | 'trance' | 'dnb' | 'hardcore' | 'harddance' | 'autres'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrackTableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|label|align|mono|dim|key|ref|className|style|children)$/]",
        "message": "<TrackTableColumn> doesn't accept that prop. Declared props: key, label, align, mono, dim."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrackTableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<TrackTableColumn> align must be one of 'left' | 'right' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
