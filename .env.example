# PostgreSQL
POSTGRES_USER=diggy
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=diggy

# SQLAlchemy (async)
DATABASE_URL=postgresql+asyncpg://diggy:your-password-here@postgres:5432/diggy

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_USER=your-minio-user
MINIO_PASSWORD=your-minio-password
MINIO_URL=http://minio:9000

# FastAPI
SECRET_KEY=your-secret-key-here

# Nginx
NGINX_PORT=8080

# HTTPS (production only)
# DOMAIN=diggy-music.fr
# COMPOSE_FILE=docker-compose.yml:docker-compose.ssl.yml
