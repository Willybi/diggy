# Nom du projet Docker Compose (isoler des autres projets sur le VPS)
COMPOSE_PROJECT_NAME=diggy

# PostgreSQL
POSTGRES_USER=diggy
POSTGRES_PASSWORD=changeme
POSTGRES_DB=diggy
DATABASE_URL=postgresql+asyncpg://diggy:changeme@postgres:5432/diggy

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# API
SECRET_KEY=changeme-generate-a-real-secret-key

# Nginx (port exposé sur l'hôte VPS)
# Changer si 8080 est déjà pris par l'autre projet
NGINX_PORT=8080
