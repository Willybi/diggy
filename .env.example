# PostgreSQL
POSTGRES_USER=diggy
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=diggy

# SQLAlchemy (async)
DATABASE_URL=postgresql+asyncpg://diggy:your-password-here@postgres:5432/diggy

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_USER=your-minio-user
MINIO_PASSWORD=your-minio-password
MINIO_URL=http://minio:9000

# Auth — JWT (required: the API reads JWT_SECRET)
JWT_SECRET=your-jwt-secret-here

# Google OAuth (required — Google is the only login method)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://diggy-music.fr/api/auth/google/callback

# App environment / CORS
# Any value other than "production" enables permissive dev CORS — set in prod.
# ENV=production
# CORS_ORIGIN=http://localhost:5173   # comma-separated allowed origins (dev default)

# Sentry (optional — error monitoring; empty string disables)
SENTRY_DSN=
# SENTRY_ENV=production

# TIDAL source (production bootstrap tokens — get them via
# `python server/scripts/test_sources.py tidal`, which stores the OAuth session).
# In dev the worker falls back to a local token file (gitignored).
# TIDAL_TOKEN_FILE=   # overrides the dev token file path (default: server/scripts/.tidal_tokens.json)
# TIDAL_ACCESS_TOKEN=
# TIDAL_REFRESH_TOKEN=
# TIDAL_TOKEN_TYPE=Bearer
# TIDAL_EXPIRY=

# Backup (server/scripts/backup.sh)
# Symmetric GPG passphrase (AES256) used to encrypt dumps.
# If unset, backups are written UNENCRYPTED.
BACKUP_ENCRYPTION_KEY=your-backup-passphrase

# Nginx (dev only — host HTTP port; prod publishes 80/443 via docker-compose.ssl.yml)
NGINX_PORT=8080

# HTTPS (production only)
# DOMAIN=diggy-music.fr
# COMPOSE_FILE=docker-compose.yml:docker-compose.ssl.yml

# C6.a — TrackID backfill
TRACKID_BACKFILL_SETS_PER_DAY=500
# TRACKID_BACKFILL_MIN_DATE=  # default: today - 730 jours (format YYYY-MM-DD)
